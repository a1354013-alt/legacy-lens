{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Legacy Lens: Start and Open",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\f5-start.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Legacy Lens: Stop Demo",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\scripts\\f5-stop.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Legacy Lens: Reset Demo DB",
      "type": "shell",
      "command": "docker compose -f docker-compose.demo.yml down -v",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Legacy Lens: Show Demo Logs",
      "type": "shell",
      "command": "docker compose -f docker-compose.demo.yml logs --tail 200 -f app migrate db",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
