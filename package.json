{
  "name": "legacy-lens",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20 <23",
    "pnpm": "10.4.1"
  },
  "scripts": {
    "dev": "pnpm exec cross-env NODE_ENV=development pnpm exec tsx watch server/_core/index.ts",
    "build": "pnpm exec cross-env NODE_ENV=production pnpm exec vite build && pnpm exec esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && pnpm exec esbuild server/services/jobWorkerThread.ts --platform=node --packages=external --bundle --format=esm --outdir=dist/services",
    "start": "pnpm exec cross-env NODE_ENV=production node dist/index.js",
    "typecheck": "pnpm exec tsc --noEmit",
    "typecheck:test": "pnpm exec tsc -p tsconfig.test.json --noEmit",
    "check": "pnpm typecheck && pnpm typecheck:test",
    "lint": "pnpm exec eslint .",
    "format": "pnpm exec prettier --write .",
    "test": "pnpm exec vitest run --exclude server/migrationSafety.test.ts",
    "test:watch": "pnpm exec vitest",
    "test:migration": "pnpm exec vitest run server/migrationSafety.test.ts",
    "docker:smoke": "node ./scripts/docker-smoke.mjs",
    "db:generate": "pnpm exec drizzle-kit generate",
    "db:migrate": "pnpm exec drizzle-kit migrate",
    "db:push": "pnpm db:generate && pnpm db:migrate"
  },
  "dependencies": {
