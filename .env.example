# Legacy Lens Environment Configuration
# Copy this file to .env and fill in the required values.

# ==============================================================================
# REQUIRED VARIABLES
# ==============================================================================

# Database connection string (MySQL 8+ or PlanetScale)
# Format: mysql://user:password@host:port/database
DATABASE_URL="mysql://root:password@localhost:3306/legacy_lens"

# Database pool tuning
# - DB_CONNECTION_LIMIT must be a positive integer.
# - DB_QUEUE_LIMIT may be 0 to disable queued connection requests; otherwise use a non-negative integer.
# - DB_WAIT_FOR_CONNECTIONS=false makes the pool fail immediately when no connection is available.
# DB_CONNECTION_LIMIT=10
# DB_QUEUE_LIMIT=0
# DB_WAIT_FOR_CONNECTIONS=true

# App identifier (required for session signing; also used by OAuth)
VITE_APP_ID="your-app-id"

# OAuth Portal URL (required; must be non-empty; placeholders are OK during dev auth bypass)
VITE_OAUTH_PORTAL_URL="https://oauth.example.com"

# JWT Secret for session signing (minimum 32 characters)
JWT_SECRET="your-jwt-secret-minimum-32-characters-long"

# OAuth Server URL (required; must be non-empty; placeholders are OK during dev auth bypass)
OAUTH_SERVER_URL="https://oauth.example.com"

# ==============================================================================
# OPTIONAL VARIABLES
# ==============================================================================

# Local development auth bypass (DEV ONLY)
# - Server: DEV_AUTH_BYPASS enables a local login endpoint at /api/dev/login
# - Client: VITE_DEV_AUTH_BYPASS makes the UI sign-in button point to /api/dev/login
# - Never enable in production.
# DEV_AUTH_BYPASS=1
# DEV_AUTH_OPEN_ID=local-dev-user
# VITE_DEV_AUTH_BYPASS=1

# Safety gate: the server disables DEV_AUTH_BYPASS when NODE_ENV=production unless this explicit override is set.
# This is intended only for containerized demo runs (not for real production use).
# Never enable this in production.
# DEV_AUTH_BYPASS_UNSAFE_ALLOW=1

# Build/runtime version metadata
# APP_VERSION should be injected by production builds or deployment automation.
# If omitted, health falls back to npm/package metadata or "unknown".
# APP_VERSION=1.0.0
# GIT_COMMIT=abcdef0

# Production Git import allowlist
# - Comma-separated host list, for example: github.com,gitlab.com
# - In production, if omitted, Legacy Lens defaults to github.com and gitlab.com only.
# - Loopback and private IP hosts are always rejected.
# LEGACY_LENS_GIT_HOST_ALLOWLIST=github.com,gitlab.com

# Reverse proxy trust setting for Express / rate limiting
# - Leave unset for direct app exposure.
# - Set this only when Legacy Lens is deployed behind a trusted reverse proxy/load balancer.
# - Examples: true, loopback, linklocal, uniquelocal, 1, 2
# LEGACY_LENS_TRUST_PROXY=loopback

# Production security headers
# - Leave CSP_ALLOW_UNSAFE_EVAL unset in real production unless the risk is explicitly accepted.
# - docker-compose.demo.yml enables it for demo bundles that may still need eval/new Function.
# CSP_ALLOW_UNSAFE_EVAL=true

# Logging
# - LOG_LEVEL defaults to info in production and debug otherwise.
# - LOG_FORMAT=json or NODE_ENV=production emits structured JSON logs.
# LOG_LEVEL=info
# LOG_FORMAT=json

# Project job crash-recovery timeout in milliseconds (default: 900000 / 15 minutes)
# - Running jobs older than this are treated as stale during startup recovery.
# - Recovery re-queues restart-safe jobs and marks stuck projects as failed with a stable recovery error.
# PROJECT_JOB_STALE_MS=900000

# Project job lease settings (defaults shown)
# - Lease/heartbeat values fence active work so stale workers cannot overwrite reclaimed jobs.
# - PROJECT_JOB_HEARTBEAT_MS must be lower than PROJECT_JOB_LEASE_MS and no more than one third of the lease.
# - Max attempts controls how many times a stale job can be retried before it fails.
# PROJECT_JOB_LEASE_MS=30000
# PROJECT_JOB_HEARTBEAT_MS=10000
# PROJECT_JOB_MAX_ATTEMPTS=3

# Project worker thread lifecycle timeouts
# - PROJECT_JOB_EXECUTION_TIMEOUT_MS bounds one claimed job execution before the worker thread is terminated.
# - PROJECT_JOB_WORKER_START_TIMEOUT_MS bounds worker startup readiness.
# PROJECT_JOB_EXECUTION_TIMEOUT_MS=1800000
# PROJECT_JOB_WORKER_START_TIMEOUT_MS=15000

# Project worker toggle (default: enabled)
# - Set PROJECT_WORKER_ENABLED=false on web-only replicas.
# - Multiple worker-enabled replicas are supported when they share the same MySQL database.
# - Project job claiming uses DB lease fields and atomic conditional updates so only one worker can own a job lease at a time.
# - Worker-enabled processes also poll MySQL for queued jobs and expired running-job leases, so they can pick up work that was enqueued by web-only replicas.
# - PROJECT_WORKER_POLL_INTERVAL_MS controls that polling cadence and must be a positive integer.
# - If your deployment cannot rely on shared-database conditional updates and transactions, run a single worker replica.
# - Local in-memory test doubles are useful for tests, but they are not a substitute for shared-MySQL deployment semantics.
# PROJECT_WORKER_ENABLED=true
# PROJECT_WORKER_ID=worker-1
# PROJECT_WORKER_POLL_INTERVAL_MS=2000

# Upload temp ZIP cleanup
# - TTL controls when orphan temp uploads can be deleted.
# - Cleanup interval controls the periodic cleanup cadence.
# UPLOAD_TEMP_ZIP_TTL_MS=86400000
# UPLOAD_TEMP_ZIP_CLEANUP_INTERVAL_MS=3600000

# Auth write throttle
# - Throttles lastSignedIn writes for repeat requests from the same session.
# LAST_SIGNED_IN_WRITE_THROTTLE_MS=900000

# Server port (default: 3000)
# PORT=3000

# Node environment (default: development)
# NODE_ENV=development

# Docker smoke / CI helper ports
# - The app itself reads PORT, but docker-compose.yml uses LEGACY_LENS_PORT and LEGACY_LENS_DB_PORT
#   to randomize host bindings during smoke tests and avoid collisions.
# LEGACY_LENS_PORT=3000
# LEGACY_LENS_DB_PORT=3306
# LEGACY_LENS_SMOKE_TIMEOUT_MS=180000

# ==============================================================================
# LOCAL DEVELOPMENT WITHOUT OAUTH
# ==============================================================================
# If you want to run local development without setting up OAuth:
# 1. Set DATABASE_URL, JWT_SECRET, VITE_APP_ID, plus placeholder OAuth URLs (VITE_OAUTH_PORTAL_URL / OAUTH_SERVER_URL)
# 2. Enable DEV_AUTH_BYPASS and VITE_DEV_AUTH_BYPASS
# 3. Click "Sign in" in the UI (it will hit /api/dev/login instead of the OAuth portal)
# ==============================================================================
