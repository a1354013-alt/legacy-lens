# Legacy Lens Environment Configuration
# Copy this file to .env and fill in the required values.

# ==============================================================================
# REQUIRED VARIABLES
# ==============================================================================

# Database connection string (MySQL 8+ or PlanetScale)
# Format: mysql://user:password@host:port/database
DATABASE_URL="mysql://root:password@localhost:3306/legacy_lens"

# OAuth Application ID (required for authentication)
# For local development without OAuth, see README.md for dev auth bypass instructions.
VITE_APP_ID="your-app-id"

# OAuth Portal URL (required for authentication flow)
VITE_OAUTH_PORTAL_URL="https://oauth.example.com"

# JWT Secret for session signing (minimum 32 characters)
JWT_SECRET="your-jwt-secret-minimum-32-characters-long"

# OAuth Server URL (required for token exchange)
OAUTH_SERVER_URL="https://oauth.example.com"

# Owner OpenID for admin notifications
OWNER_OPEN_ID="your-open-id"

# ==============================================================================
# OPTIONAL VARIABLES
# ==============================================================================

# Forge API integration (optional, for advanced features)
# BUILT_IN_FORGE_API_URL="https://forge.example.com"
# BUILT_IN_FORGE_API_KEY="your-forge-api-key"

# Server port (default: 3000)
# PORT=3000

# Node environment (default: development)
# NODE_ENV=development

# ==============================================================================
# LOCAL DEVELOPMENT WITHOUT OAUTH
# ==============================================================================
# If you want to run local development without setting up OAuth:
# 1. Set VITE_APP_ID to any non-empty value (e.g., "local-dev")
# 2. The application requires OAuth configuration at runtime.
#    For true local dev without OAuth, you would need to implement
#    a dev auth bypass mode (not included in this version).
# 3. All protected routes require authentication via the configured OAuth provider.
# ==============================================================================
