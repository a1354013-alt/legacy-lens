# Legacy Lens Environment Configuration
# Copy this file to .env and fill in the required values.

# ==============================================================================
# REQUIRED VARIABLES
# ==============================================================================

# Database connection string (MySQL 8+ or PlanetScale)
# Format: mysql://user:password@host:port/database
DATABASE_URL="mysql://root:password@localhost:3306/legacy_lens"

# App identifier (required for session signing; also used by OAuth)
VITE_APP_ID="your-app-id"

# OAuth Portal URL (required; OK to use placeholders during dev auth bypass)
VITE_OAUTH_PORTAL_URL="https://oauth.example.com"

# JWT Secret for session signing (minimum 32 characters)
JWT_SECRET="your-jwt-secret-minimum-32-characters-long"

# OAuth Server URL (required; OK to use placeholders during dev auth bypass)
OAUTH_SERVER_URL="https://oauth.example.com"

# ==============================================================================
# OPTIONAL VARIABLES
# ==============================================================================

# Local development auth bypass (DEV ONLY)
# - Server: DEV_AUTH_BYPASS enables a local login endpoint at /api/dev/login
# - Client: VITE_DEV_AUTH_BYPASS makes the UI sign-in button point to /api/dev/login
# - Never enable in production.
# DEV_AUTH_BYPASS=1
# DEV_AUTH_OPEN_ID=local-dev-user
# VITE_DEV_AUTH_BYPASS=1

# Safety gate: the server disables DEV_AUTH_BYPASS when NODE_ENV=production unless this explicit override is set.
# This is intended only for containerized demo runs (not production deployment).
# DEV_AUTH_BYPASS_UNSAFE_ALLOW=1

# Server port (default: 3000)
# PORT=3000

# Node environment (default: development)
# NODE_ENV=development

# ==============================================================================
# LOCAL DEVELOPMENT WITHOUT OAUTH
# ==============================================================================
# If you want to run local development without setting up OAuth:
# 1. Set DATABASE_URL, JWT_SECRET, VITE_APP_ID, plus placeholder OAuth URLs (VITE_OAUTH_PORTAL_URL / OAUTH_SERVER_URL)
# 2. Enable DEV_AUTH_BYPASS and VITE_DEV_AUTH_BYPASS
# 3. Click "Sign in" in the UI (it will hit /api/dev/login instead of the OAuth portal)
# ==============================================================================
